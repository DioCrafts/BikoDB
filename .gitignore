# =============================================================================
# BikoDB .gitignore
# =============================================================================

# ── Rust / Cargo ─────────────────────────────────────────────────────────────
/target/
**/*.rs.bk
*.pdb

# ── Cargo.lock ───────────────────────────────────────────────────────────────
# Included for reproducible builds (this is a workspace with binaries).
# Do NOT ignore Cargo.lock for applications; only ignore for libraries.
# Cargo.lock

# ── Compiled artifacts ───────────────────────────────────────────────────────
*.o
*.d
*.rlib
*.rmeta
*.dylib
*.so
*.dll
*.a
*.lib
*.exe

# ── Benchmarks output ────────────────────────────────────────────────────────
# Criterion benchmark data (regenerable)
target/criterion/

# ── External competitor repositories (cloned for comparison) ─────────────────
/arcadedb/
/kuzu/
/neo4j/

# ── OS files ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
._*

# ── IDE / Editors ────────────────────────────────────────────────────────────
# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains (CLion, IntelliJ IDEA, RustRover)
.idea/
*.iml
*.iws
*.ipr

# Vim / Neovim
*.swp
*.swo
*~
tags
.nvimrc
.exrc

# Emacs
\#*\#
.#*
*.elc

# Sublime Text
*.sublime-project
*.sublime-workspace

# ── Environment / secrets ────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.crt
*.p12

# ── Data / runtime files ────────────────────────────────────────────────────
# BikoDB data directories (created at runtime)
data/
*.db
*.wal
*.snap
*.bikodb

# Temporary files
*.tmp
*.temp
*.bak
*.orig

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Coverage / profiling ────────────────────────────────────────────────────
*.profraw
*.profdata
lcov.info
tarpaulin-report.html
coverage/

# ── Documentation build ─────────────────────────────────────────────────────
# mdBook output (if used in the future)
docs/book/

# ── Python (bikodb-python FFI) ───────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.whl
.venv/
venv/
env/

# ── Node.js (bikodb-node FFI) ───────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
.npm/

# ── Docker ───────────────────────────────────────────────────────────────────
docker-compose.override.yml
